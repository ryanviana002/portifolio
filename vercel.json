{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/preview.js": { "maxDuration": 60 },
    "api/preview-check.js": { "maxDuration": 30 }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/delega", "dest": "/delega/index.html" },
    { "src": "/delega/(.*)", "dest": "/delega/$1" },
    { "src": "/estocao", "dest": "/estocao/index.html" },
    { "src": "/estocao/(.*)", "dest": "/estocao/$1" },
    { "src": "/lrmarcal", "dest": "/lrmarcal/index.html" },
    { "src": "/lrmarcal/(.*)", "dest": "/lrmarcal/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
